# Klaviyo — public (safe to expose in browser bundles)
# Get from: Klaviyo → Settings → Account → API Keys → Public API Key
PUBLIC_KLAVIYO_KEY=pk_XXXXXXXXXXXXXXXXXXXXXXXXXXXX

# The Klaviyo list ID for waitlist signups.
# Get from: Klaviyo → Lists → your list → URL (…/lists/XXXXXX/...)
PUBLIC_KLAVIYO_LIST_ID=XXXXXX
